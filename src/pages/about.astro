---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'About — Clarity AI',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About"
  >
    <Fragment slot="title">
      <div class="flex justify-center mb-4">
        <img
          src="/images/mayank-bhasin-profile.jpg"
          alt="Mayank Bhasin"
          class="w-32 h-32 rounded-full object-cover border-4 border-blue-500 shadow-lg"
          loading="eager"
        />
      </div>
      Mayank Bhasin
      <span class="block text-2xl mt-2 text-accent">Founder, Clarity AI</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="text-lg">
        AI-First Product & Program Executive | Principal PM at Microsoft | GenAI, Agentic AI & Enterprise Transformation
      </span>
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Experience & Impact"
    stats={[
      { title: 'Years of Experience', amount: '21+' },
      { title: 'Markets Served', amount: 'Global' },
      { title: 'Focus', amount: 'AI-First' },
      { title: 'Active Mentor', amount: '6 Programs' },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'AI & Cloud Transformation',
        description:
          'Building transformative technology solutions across AI, cloud, and digital platforms at Microsoft, Oracle, and Nokia.',
      },
      {
        title: 'Product Leadership',
        description:
          'Led multi-million-dollar portfolios delivering scalable solutions across Asia, Europe, and North America.',
      },
      {
        title: 'Enterprise Solutions',
        description:
          'Helping enterprise customers drive adoption of AI-powered management solutions and resilient operating systems at scale.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Team collaboration',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Who I Am
      </h2>
      <p class="text-muted mb-4">
        I'm an AI-focused Product & Program Leader with 21+ years of global experience at the intersection of Artificial Intelligence, Cloud platforms, and enterprise transformation.
      </p>
      <p class="text-muted mb-4">
        At <strong>Microsoft</strong>, I build and deploy <strong>agentic AI solutions</strong> — intelligent agents powered by LLMs, Semantic Kernel, and Azure AI that automate customer insight capture, engineering workflows, and decision-making. I led <strong>Copilot+ PC commercial readiness</strong> across 200M+ devices and drive enterprise AI adoption through hands-on workshops and GenAI PoCs.
      </p>
      <p class="text-muted">
        I'm passionate about applying AI to product management — from AI-powered roadmap prioritization to agentic workflows that transform how products are built and delivered.
      </p>
    </Fragment>
  </Content>

  <!-- Features3 Widget ************** -->

  <Features3
    title="Core Expertise"
    subtitle="Deep technical knowledge across AI, cloud, and enterprise solutions"
    columns={3}
    items={[
      {
        title: 'AI-Driven Product Strategy',
        description:
          'Building intelligent agents using generative AI and copilot technologies, supporting organizations in adopting AI through agent-based deployments that drive measurable business outcomes.',
        icon: 'tabler:brain',
      },
      {
        title: 'Cloud Transformation',
        description:
          'Leading cloud adoption and digital transformation initiatives across Azure, AWS, and Oracle Cloud platforms at enterprise scale.',
        icon: 'tabler:cloud',
      },
      {
        title: 'Enterprise Platform Engineering',
        description:
          'Expert in AI-powered management solutions, enterprise operating systems, and resilience initiatives for global customers.',
        icon: 'tabler:brand-windows',
      },
      {
        title: 'Product Leadership',
        description:
          'Led multi-million-dollar portfolios at Microsoft, Oracle, and Nokia, delivering scalable solutions across diverse global markets.',
        icon: 'tabler:rocket',
      },
      {
        title: 'User-Centric Innovation',
        description:
          'Designing secure, intelligent, and scalable commercial experiences that prioritize user needs and business outcomes.',
        icon: 'tabler:users',
      },
      {
        title: 'Global Enterprise Solutions',
        description:
          'Delivering transformative solutions across UK, EMEA, US, Asia, and North America markets.',
        icon: 'tabler:world',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Multi-Million Dollar Portfolios',
        description:
          'Successfully led and delivered complex, high-value product initiatives across Microsoft, Oracle, and Nokia.',
      },
      {
        title: 'Global Market Experience',
        description:
          'Proven track record delivering solutions across diverse markets from Asia to Europe and North America.',
      },
      {
        title: 'AI Agent Development',
        description:
          'Actively building intelligent agents using generative AI and copilot technologies for measurable business impact.',
      },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Track Record
      </h2>
      <p class="text-muted">
        I've led multi-million-dollar portfolios at Microsoft, Oracle, and Nokia, delivering scalable solutions
        across diverse markets—from Asia to Europe and North America. I'm deeply involved in building intelligent
        agents using generative AI and copilot technologies, supporting organizations in adopting AI through agent-based
        deployments that drive measurable business outcomes.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Mentorship Section -->

  <Features3
    title="Mentorship & Community Impact"
    subtitle="Committed to developing the next generation of AI and product leaders"
    columns={3}
    items={[
      {
        title: 'Lead Instructor — BrainStation',
        description:
          'Teaching Product Leadership to aspiring product managers, helping them develop strategic thinking and AI-first execution skills.',
        icon: 'tabler:school',
      },
      {
        title: 'Mentor — Pi515',
        description:
          'Mentoring underrepresented professionals in technology, leadership development, and career advancement in AI and product roles.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Mentor — Migrant Leaders',
        description:
          'Supporting migrant professionals in building leadership skills, navigating career transitions, and accessing opportunities in the UK tech industry.',
        icon: 'tabler:world',
      },
      {
        title: 'Mentor — Female Palette',
        description:
          'Supporting women in tech through mentorship, career guidance, and leadership development.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Volunteer Mentor — ITSB',
        description:
          'Guiding at-risk children in digital literacy, problem-solving, and STEM career pathways.',
        icon: 'tabler:heart',
      },
      {
        title: 'AI & PM Career Mentoring',
        description:
          'Mentoring students, early-career professionals, and experienced leaders pivoting into AI, product management, and agentic AI roles.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-800"></div>
    </Fragment>
  </Features3>

  <!-- Certifications -->

  <Features2
    title="Certifications & Credentials"
    subtitle="Continuous learning across AI, cloud, and product management"
    columns={3}
    items={[
      {
        title: 'Microsoft 365: Copilot & Agent Admin',
        description: 'Copilot and Agent Administration Fundamentals (2026)',
        icon: 'tabler:certificate-2',
      },
      {
        title: 'MS AI Business Professional',
        description: 'Microsoft Certified: AI Business Professional (2026)',
        icon: 'tabler:certificate-2',
      },
      {
        title: 'MS AI Transformation Leader',
        description: 'Microsoft Certified: AI Transformation Leader (2026)',
        icon: 'tabler:certificate-2',
      },
      {
        title: 'Azure AI Fundamentals (AI-900)',
        description: 'Microsoft Azure AI expertise (2023)',
        icon: 'tabler:certificate',
      },
      {
        title: 'Azure Cloud (AZ-900)',
        description: 'Microsoft Azure cloud platform (2022)',
        icon: 'tabler:certificate',
      },
      {
        title: 'Oracle Cloud Infrastructure',
        description: 'Cloud architecture & security on OCI (2021)',
        icon: 'tabler:certificate',
      },
      {
        title: 'AWS Cloud',
        description: 'Cloud architecture & deployment on AWS (2019)',
        icon: 'tabler:certificate',
      },
      {
        title: 'PMP',
        description: 'Project Management Professional',
        icon: 'tabler:certificate',
      },
      {
        title: 'DevOps & Agile',
        description: 'DASA, KnowIT, DevOpsGuys (2017)',
        icon: 'tabler:certificate',
      },
    ]}
  />

  <!-- CTA Section -->

  <Content
    isAfterContent
    items={[
      {
        title: 'AI Business Transformation',
        description:
          'Exploring how AI can transform your business with practical, agent-based deployments.',
      },
      {
        title: 'Product Strategy Collaboration',
        description:
          'Developing innovative product strategies that deliver measurable outcomes.',
      },
      {
        title: 'Mentorship & Growth',
        description:
          'Passionate about mentoring the next generation of tech leaders.',
      },
    ]}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Let's Connect
      </h2>
      <p class="text-muted mb-4">
        I'm always interested in connecting with people who are:
      </p>
      <ul class="text-muted list-disc list-inside space-y-2">
        <li>Exploring how AI can transform their business</li>
        <li>Looking to collaborate on innovative product strategies</li>
        <li>Passionate about mentoring and professional growth</li>
        <li>Building intelligent agents and AI-driven solutions</li>
      </ul>
    </Fragment>
  </Content>
</Layout>
